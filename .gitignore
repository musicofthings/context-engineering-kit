# Secrets & credentials
.env
.env.*
*.pem
*.key
*.p12
secrets/
credentials/

# Session history (large; keep state.json but not full history unless needed)
.claude/session/history.jsonl

# Audit logs (local only)
.claude/config-audit.log
.claude/compact-audit.log

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Node / npm
node_modules/
dist/
build/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Editor
.vscode/settings.json
.idea/
*.swp

# API docs (regenerated by CI)
api_docs.md

# Daily morning briefs (generated locally, not committed)
briefs/

# But DO commit these session files:
!.claude/session/state.json

# Local settings (machine-specific, not committed)
.claude/settings.local.json

# Usage sentinel state files (session-local)
.claude/session/.sentinel_*

# Usage summary cache (regenerated by usage_report.py)
.claude/session/usage_summary.json
