#!/usr/bin/env python3
"""
usage-tracker.py
Called by the Stop hook (async) after every response turn.
Reads token/cost data from the Stop event, accumulates in daily-usage.json,
predicts exhaustion, and writes usage-forecast.json with recommendations.

Called as: python3 scripts/usage-tracker.py [--report]
  --report: print a human-readable forecast instead of running as hook
"""

import argparse
import json
import os
import sys
from datetime import datetime, timezone, timedelta
from pathlib import Path


PROJECT_DIR = Path(os.environ.get("CLAUDE_PROJECT_DIR", "."))
SESSION_DIR = PROJECT_DIR / ".claude" / "session"
DAILY_USAGE_FILE  = SESSION_DIR / "daily-usage.json"
FORECAST_FILE     = SESSION_DIR / "usage-forecast.json"
TIMESTAMP_FMT     = "%Y-%m-%dT%H:%M:%SZ"

# ── Subscription tier limits (approximate — adjust in config) ───────────────
# These are estimates. Pro/Max are rate-limited by rolling windows, not hard
# daily token caps. We track cost-in-USD as a proxy signal.
TIER_LIMITS = {
    "pro": {
        "daily_cost_warn_usd":    0.50,   # warn at 50 cents/day
        "daily_cost_critical_usd": 0.90,  # critical at 90 cents/day
        "session_window_hours":   5,       # Pro: 5-hour rolling windows
        "note": "Pro uses 5-hour usage windows, not daily token caps"
    },
    "max": {
        "daily_cost_warn_usd":    2.00,
        "daily_cost_critical_usd": 4.00,
        "session_window_hours":   5,
        "note": "Max: 5x Pro limits"
    },
    "api": {
        "daily_cost_warn_usd":    5.00,
        "daily_cost_critical_usd": 9.00,
        "session_window_hours":   None,
        "note": "API billing: pure token cost"
    }
}

# Load subscription type from config
def get_subscription_tier() -> str:
    config_file = PROJECT_DIR / "config" / "rate_limits.json"
    if config_file.exists():
        try:
            cfg = json.loads(config_file.read_text())
            # Check for tier hint in env or config
            return cfg.get("subscription_tier", "pro")
        except Exception:
            pass
    return os.environ.get("CEK_SUBSCRIPTION_TIER", "pro")


def utc_now() -> datetime:
    return datetime.now(timezone.utc)


def today_key() -> str:
    return utc_now().strftime("%Y-%m-%d")


def load_daily_usage() -> dict:
    if DAILY_USAGE_FILE.exists():
        try:
            return json.loads(DAILY_USAGE_FILE.read_text())
        except Exception:
            pass
    return {}


def save_daily_usage(data: dict):
    SESSION_DIR.mkdir(parents=True, exist_ok=True)
    DAILY_USAGE_FILE.write_text(json.dumps(data, indent=2))


def load_forecast() -> dict:
    if FORECAST_FILE.exists():
        try:
            return json.loads(FORECAST_FILE.read_text())
        except Exception:
            pass
    return {}


def save_forecast(data: dict):
    SESSION_DIR.mkdir(parents=True, exist_ok=True)
    FORECAST_FILE.write_text(json.dumps(data, indent=2))


def ingest_stop_event(stop_input: dict) -> dict:
    """Extract usage metrics from a Stop event input."""
    # Stop event provides cost summary for the full session so far
    cost = stop_input.get("cost", {})
    usage = stop_input.get("usage", {})

    return {
        "session_cost_usd":     cost.get("totalCostUSD", 0.0),
        "session_input_tokens":  cost.get("totalInputTokens",
                                          usage.get("input_tokens", 0)),
        "session_output_tokens": cost.get("totalOutputTokens",
                                          usage.get("output_tokens", 0)),
        "session_duration_ms":   cost.get("totalDurationMS", 0),
        "session_turns":         stop_input.get("turn_count", 0),
        "stop_reason":           stop_input.get("stop_reason", "end_turn"),
    }


def accumulate_daily(metrics: dict) -> dict:
    """Accumulate today's usage, tracking incremental cost per turn."""
    data   = load_daily_usage()
    key    = today_key()
    now_ts = utc_now().strftime(TIMESTAMP_FMT)

    if key not in data:
        data[key] = {
            "date":               key,
            "turns":              0,
            "input_tokens":       0,
            "output_tokens":      0,
            "cost_usd":           0.0,
            "sessions":           [],
            "first_activity":     now_ts,
            "last_activity":      now_ts,
            "peak_cost_per_turn": 0.0,
        }

    day = data[key]

    # We track cumulative session cost — derive per-turn increment
    session_id = os.environ.get("CLAUDE_SESSION_ID", "unknown")
    prev_session_cost = 0.0
    for s in day["sessions"]:
        if s.get("session_id") == session_id:
            prev_session_cost = s.get("last_cost_usd", 0.0)
            break

    turn_cost = max(0.0, metrics["session_cost_usd"] - prev_session_cost)

    # Update or add session entry
    session_entry = {
        "session_id":     session_id,
        "last_cost_usd":  metrics["session_cost_usd"],
        "turns":          metrics["session_turns"],
        "updated":        now_ts,
    }
    day["sessions"] = [
        s for s in day["sessions"] if s.get("session_id") != session_id
    ]
    day["sessions"].append(session_entry)

    # Accumulate totals
    day["turns"]         += 1
    day["input_tokens"]  += metrics["session_input_tokens"]
    day["output_tokens"] += metrics["session_output_tokens"]
    day["cost_usd"]      += turn_cost
    day["last_activity"]  = now_ts

    if turn_cost > day["peak_cost_per_turn"]:
        day["peak_cost_per_turn"] = turn_cost

    data[key] = day
    save_daily_usage(data)
    return day


def compute_forecast(day: dict, tier_name: str) -> dict:
    """Predict exhaustion time and recommend action."""
    tier    = TIER_LIMITS.get(tier_name, TIER_LIMITS["pro"])
    now     = utc_now()

    warn_limit     = tier["daily_cost_warn_usd"]
    critical_limit = tier["daily_cost_critical_usd"]
    cost_today     = day.get("cost_usd", 0.0)
    turns_today    = max(1, day.get("turns", 1))

    # Burn rate: cost per turn
    cost_per_turn = cost_today / turns_today

    # Time-based burn rate (cost per hour)
    first_str = day.get("first_activity", now.strftime(TIMESTAMP_FMT))
    try:
        first_dt = datetime.fromisoformat(first_str.replace("Z", "+00:00"))
        elapsed_hours = max(0.01, (now - first_dt).total_seconds() / 3600)
    except Exception:
        elapsed_hours = 1.0
    cost_per_hour = cost_today / elapsed_hours

    # Predict turns/hours to limits
    remaining_to_warn     = max(0.0, warn_limit - cost_today)
    remaining_to_critical = max(0.0, critical_limit - cost_today)

    turns_to_warn     = int(remaining_to_warn / cost_per_turn)     if cost_per_turn > 0 else 9999
    turns_to_critical = int(remaining_to_critical / cost_per_turn) if cost_per_turn > 0 else 9999
    hours_to_critical = remaining_to_critical / cost_per_hour      if cost_per_hour > 0 else 99.0

    # Determine status
    pct = (cost_today / critical_limit * 100) if critical_limit > 0 else 0
    if pct >= 90:
        status = "CRITICAL"
        bar    = "🔴"
        action = "compact_smart_now"
    elif pct >= 70:
        status = "WARNING"
        bar    = "🟠"
        action = "compact_smart_soon"
    elif pct >= 50:
        status = "CAUTION"
        bar    = "🟡"
        action = "monitor"
    else:
        status = "HEALTHY"
        bar    = "🟢"
        action = "none"

    # ETA to critical
    if hours_to_critical < 0.5:
        eta_str = f"~{int(hours_to_critical * 60)} minutes"
    elif hours_to_critical < 99:
        eta_str = f"~{hours_to_critical:.1f} hours"
    else:
        eta_str = "beyond today"

    forecast = {
        "updated":             now.strftime(TIMESTAMP_FMT),
        "tier":                tier_name,
        "status":              status,
        "indicator":           bar,
        "recommended_action":  action,
        "cost_today_usd":      round(cost_today, 4),
        "warn_limit_usd":      warn_limit,
        "critical_limit_usd":  critical_limit,
        "pct_of_critical":     round(pct, 1),
        "turns_today":         turns_today,
        "cost_per_turn_usd":   round(cost_per_turn, 5),
        "cost_per_hour_usd":   round(cost_per_hour, 4),
        "turns_to_warn":       turns_to_warn,
        "turns_to_critical":   turns_to_critical,
        "eta_to_critical":     eta_str,
        "tier_note":           tier.get("note", ""),
    }

    return forecast


def should_auto_compact(forecast: dict) -> bool:
    """Return True if we should trigger auto compaction."""
    return forecast["recommended_action"] in ("compact_smart_now", "compact_smart_soon") \
        or forecast["turns_to_critical"] < 10


def format_report(forecast: dict, day: dict) -> str:
    """Human-readable usage report for /usage-forecast skill."""
    f = forecast
    lines = [
        "╔══════════════════════════════════════════════════╗",
        f"║  Usage Forecast  {f['indicator']}  {f['status']:<10}                 ║",
        "╚══════════════════════════════════════════════════╝",
        "",
        f"Subscription tier : {f['tier'].upper()}",
        f"Cost today        : ${f['cost_today_usd']:.4f} / ${f['critical_limit_usd']:.2f} ({f['pct_of_critical']:.1f}%)",
        f"Burn rate         : ${f['cost_per_turn_usd']:.5f}/turn  |  ${f['cost_per_hour_usd']:.4f}/hr",
        f"Turns today       : {f['turns_today']}",
        "",
        f"To warn limit     : {f['turns_to_warn']} more turns",
        f"To critical       : {f['turns_to_critical']} more turns  ({f['eta_to_critical']})",
        "",
    ]

    action = f["recommended_action"]
    if action == "compact_smart_now":
        lines += [
            "⚡ RECOMMENDED ACTION: Run /compact-smart NOW",
            "   Usage is approaching critical threshold.",
            "   After compacting, run /handover to preserve task state.",
        ]
    elif action == "compact_smart_soon":
        lines += [
            "⚠️  RECOMMENDED ACTION: Plan to run /compact-smart soon",
            f"   ~{f['turns_to_critical']} turns remaining at current burn rate.",
            "   Run /handover before compacting to preserve task state.",
        ]
    else:
        lines.append("✅ Usage is healthy. No action needed.")

    lines += [
        "",
        f"Note: {f['tier_note']}",
        "Adjust limits in config/rate_limits.json",
    ]

    return "\n".join(lines)


def run_as_hook():
    """Called by Stop hook — reads stdin, updates files, optionally triggers compact."""
    raw = sys.stdin.read().strip()
    if not raw:
        sys.exit(0)

    try:
        stop_input = json.loads(raw)
    except Exception:
        sys.exit(0)

    tier    = get_subscription_tier()
    metrics = ingest_stop_event(stop_input)
    day     = accumulate_daily(metrics)
    forecast = compute_forecast(day, tier)
    save_forecast(forecast)

    # If critical: emit a warning to stdout (injected into Claude's context)
    if forecast["status"] in ("WARNING", "CRITICAL"):
        turns_left = forecast["turns_to_critical"]
        eta        = forecast["eta_to_critical"]
        cost_pct   = forecast["pct_of_critical"]

        print(
            f"\n[usage-forecast] {forecast['indicator']} {forecast['status']}: "
            f"{cost_pct:.0f}% of daily budget used. "
            f"~{turns_left} turns remaining ({eta} at current burn rate). "
            f"Run /compact-smart to extend session.",
            file=sys.stdout
        )

    sys.exit(0)


def run_as_report():
    """Print forecast report for /usage-forecast skill."""
    tier    = get_subscription_tier()
    data    = load_daily_usage()
    key     = today_key()
    day     = data.get(key, {"cost_usd": 0.0, "turns": 0,
                              "first_activity": utc_now().strftime(TIMESTAMP_FMT)})
    forecast = compute_forecast(day, tier)
    print(format_report(forecast, day))


if __name__ == "__main__":
    parser = argparse.ArgumentParser()
    parser.add_argument("--report", action="store_true",
                        help="Print human-readable forecast (for /usage-forecast skill)")
    args = parser.parse_args()

    if args.report:
        run_as_report()
    else:
        run_as_hook()
